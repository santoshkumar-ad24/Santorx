  <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Your hub for tech insights, blogs and futuristic ideas.">
    <meta name="keywords" content="Tech Blogs, Technology, Programming, Software Development, Tech News, Coding, Future Tech, Tech Reviews">
    <title>Contact | RSantoshX</title>
    <link rel="stylesheet" href="stylesheet/contact.css">
    <link rel="stylesheet" href="stylesheet/style.css">
</head>
<body>

    
    <!-- Navigation -->
    <header>
        <navbar>
            <nav>
                
                <div class="logo">
                    <img src="/image/logo.png" alt="logo-image" class="logo-image">
                    <h1>RSantosh<span>X</span></h1>
                </div>
                <input type="checkbox" id="menu-toggle" style="display: none;">
                <label for="menu-toggle" class="hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </label>
                <div class="nav-link menu">
                    <a href="/">Home</a>
                    <a href="/blog">Blog</a>
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                </div>
            </nav>
        </navbar>
    </header>

    <!-- Main Contact Section -->
    <section class="contact-container">
        <div class="glass-card">
            
            <!-- Left Side: Contact Info -->
            <div class="contact-info">
                <div>
                    <h2>Let's Connect</h2>
                    <p>Have a topic you want us to cover? Need futuristic insights? Reach out to us directly.</p>
                    
                    <div class="info-item">
                        <div class="icon-box">@</div>
                        <span>santosh@gmail.com</span>
                    </div>
                    
                </div>

                <div class="social-links">
                    <a href="#" class="social-btn">FB</a>
                    <a href="#" class="social-btn">TW</a>
                    <a href="#" class="social-btn">IG</a>
                    <a href="#" class="social-btn">LN</a>
                </div>
            </div>

            <!-- Right Side: Contact Form -->
            <div class="contact-form">
                <form action="contact-inquiry" method="post">
                    <div class="form-group">
                        <label for="name">Your Name</label>
                        <input type="text" id="name" class="form-control" name="name" placeholder="John Doe">
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" class="form-control" name="email" placeholder="john@example.com">
                    </div>

                    <div class="form-group">
                        <label for="subject">Subject</label>
                        <select id="subject" class="form-control" name="inquiry">
                            <option>General Inquiry</option>
                            <option>Guest Posting</option>
                            <option>Sponsorship</option>
                            <option>Report a Bug</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" class="form-control" placeholder="Write your thoughts here..."></textarea>
                    </div>

                    <button type="submit" class="btn-submit">Send Me</button>
                </form>
            </div>

        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
    <div class="footer-wrapper">

        <div class="f-col brand">
            <div class="logo">
                <img src="/image/logo.png" alt="logo-image" class="logo-image">
                <h2>RSantosh<span>X</span></h2>
            </div>
            <p>Your hub for tech insights, blogs and futuristic ideas.</p>
        </div>

        <div class="f-col">
            <h4>Explore</h4>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/blog">Blogs</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </div>

        <div class="f-col">
            <h4>Community</h4>
            <ul>
                <li><a href="#">Facebook</a></li>
                <li><a href="#">GitHub</a></li>
                <li><a href="#">Instagram</a></li>
                <li><a href="#">Twitter</a></li>
            </ul>
        </div>

    </div>

    <div class="footer-bottom">
        © 2025 RSantoshX — All rights reserved.
    </div>
</footer>

</body>
</html>