<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saniova Admin | Command Center</title>

    <link rel="stylesheet" href="/stylesheet/my_blog.css">
    <link rel="stylesheet" href="/stylesheet/admin-dash.css">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">
    
    <!-- Vercel Web Analytics -->
    <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
</head>
<body>

    <div class="admin-layout">
        <!-- Modern Vertical Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="logo">
                    <img src="/image/logo.png" alt="logo-image" class="logo-image">
                    <h2>Saniova</h2>
                </div>
            </div>

            <nav class="sidebar-menu">
                <a href="#" class="menu-item active">
                    <i class="fas fa-chart-line"></i> <span>Dashboard</span>
                </a>
                <a href="/admin/details" class="menu-item">
                    <i class="fas fa-user-shield"></i> <span>Profile</span>
                </a>
                <a href="/admin/dashboard/feedback" class="menu-item">
                    <i class="fas fa-comment-dots"></i> <span>FeedBack</span>
                </a>
                <a href="/admin/dashboard/contact-inqury" class="menu-item">
                    <i class="fas fa-envelope-open-text"></i> <span>Inquiry</span>
                </a>
            </nav>

            <div class="sidebar-bottom">
                <a href="/" class="external-link">
                    <i class="fas fa-eye"></i> <span>View Site</span>
                </a>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="workspace">
            <!-- Top Navigation Bar -->
            <header class="top-nav">
                <div class="nav-left">
                    <a href="/admin/details" class="profile-link">
                        <div class="profileImg">
                            <img src="<%= blog[0].adminId.adminImage %>" alt="Profile">
                        </div>
                    </a>
                </div>
                <div class="nav-right">
                    <a href="/admin/dashboard/create-blog" class="action-btn">
                        <i class="fas fa-plus"></i> Add New Blog
                    </a>
                    
                </div>
            </header>

            <!-- Stats Highlight Grid -->
            <section class="stats-overview">
                <div class="stat-card-glass">
                    <div class="stat-info">
                        <p>Total Blogs</p>
                        <h3><%= blog.length %></h3>
                    </div>
                    <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
                </div>
            </section>

            <!-- Main Content: The Feed -->
            <section class="feed-section">
                <div class="section-header">
                    <h3>The Feed</h3>
                    <div class="filter-btns">
                        <button class="filter-btn active">All</button>
                    </div>
                </div>

                <div class="article">
                    <% for( let index=0; index < blog.length; index++ ) { %>
                        <div class="blogs-card">
                            <div class="img-blog">
                                <img src="<%= blog[index].imageUrl %>" alt="<%= blog[index].slug %>">
                            </div>
                            <div class="blog-card-content">
                                <span class="blog-category"><%= blog[index].category %></span>
                                <h2 class="blog-title"><%= blog[index].title %></h2>
                                <p class="blog-excerpt"><%= blog[index].metaDescription %></p>
                                
                                <div class="operate-blog">
                                   <a href="/admin/dashboard/edit/<%= blog[index].id %>" class="edit-btn">Edit</a> 
                                    <form action="/admin/dashboard/delete/<%= blog[index].id %>" method="post">
                                        <button type="submit" class="delete-btn">Delete</button>
                                    </form>
                                </div>
                                <div class="blog-footer">
                                    <span class="blog-date"><%= blog[index].Date.toDateString() %></span>
                                    <a href="/blog/<%= blog[index].slug %>" class="read-more">Read Article →</a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

</body>
</html>