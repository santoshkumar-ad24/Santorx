    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style"
        href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap">

    <noscript>
        <link rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap">
    </noscript>
    <link rel="stylesheet" href="/stylesheet/style.css">
    <link rel="stylesheet" href="/stylesheet/blog.css">
    <link rel="stylesheet" href="/stylesheet/hamburger-menu.css">
</head>

<body>
    <header>
        <nav>

            <div class="logo">
                <img src="/image/logo.png" alt="logo-image" class="logo-image">
                <a href="/"><h2>Saniova</h2></a>
            </div>
            <input type="checkbox" id="menu-toggle" style="display: none;">
            <label for="menu-toggle" class="menu-backdrop" aria-hidden="true"></label>
            <label for="menu-toggle" class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </label>
            <div class="nav-link menu">
                <a href="/">Home</a>
                <a href="/blog">Blog</a>
                <a href="/about">About</a>
                <a href="/privacy-policy">Privacy</a>
                <a href="/contact">Contact</a>
            </div>
        </nav>
        </navbar>
    </header>
    <main>

        <section class="blogSec">
            <article>
                <!-- Hero Section with Title -->
                <div class="blog-hero">
                    <h1 class="blog-title">
                        <%= blog.title %>
                    </h1>

                    <!-- Author & Date Card -->
                    <div class="uploader">
                        <div class="uploader-img">
                            <img src="<%= blog.adminId.adminImage %>" alt="admin-profile-image" width="60" height="60">
                        </div>
                        <div id="uploader-details">
                            <div class="uploader-det">
                                <p id="uploader-name">
                                    <%= blog.adminId.adminName %>
                                </p>
                                <p id="uploader-date">
                                    <%= blog.Date.toDateString() %>
                                </p>
                            </div>
                            <div class="blog-meta">
                                <span class="read-time">📖 3 min read</span>
                            </div>
                        </div>
                    </div>
                </div>



                <!-- Main Content Section -->
                <div class="blog-container">

                    <aside class="share-aside">
                        <!-- Share Section -->
                        <div class="share-section">
                            <h3>Share this article</h3>
                            <div class="share-buttons">
                                <a href="#" id="shareBtn-facebook" class="share-btn facebook"
                                    title="Share on Facebook">f</a>
                                <a href="#" id="shareBtn-twitter" class="share-btn twitter"
                                    title="Share on Twitter">𝕏</a>
                                <a href="#" id="shareBtn-linkedin" class="share-btn linkedin"
                                    title="Share on LinkedIn">in</a>
                                <a href="#" id="copyLinkBtn" class="share-btn copy" title="Copy Link">🔗</a>
                            </div>
                        </div>
                    </aside>
                    <!-- Main Content -->


                    <div class="content-container">
                        <!-- Featured Image with Shadow -->
                        <div class="contentImg">
                            <img src="<%= blog.imageUrl %>" alt="<%= blog.slug %>" loading="lazy">
                        </div>

                        <!-- Blog Body Content -->
                        <div class="content">
                            <p>
                                <%- blog.content %>
                            </p>
                        </div>


                    </div>


                    <!-- Sidebar -->
                </div>
                <section class="blog-recommendation">

                    <!-- Recommended Posts -->
                    <div class="blogList-container">
                        <h3 class="recommended-title">Recommended Posts</h3>

                        <!-- <div class="blog-reco-box"> -->
                        <div class="box-reco-blog">
                            <% let featuredBlog; do { featuredBlog=Math.floor(Math.random() * blogList.length); } while
                            (blogList[featuredBlog].slug===blogSlug); %>

                                <div class="blogList1">
                                    <a href="/blog/<%= blogList[featuredBlog].slug %>" class="featured-blog-post">
                                        <div class="feat-reco-image">
                                            <img src="<%= blogList[featuredBlog].imageUrl %>"
                                                alt="<%= blogList[featuredBlog].slug %>" loading=" lazy">
                                        </div>
                                        <div class="feat-blogList-details">
                                            <p class="feat-blogList-title">
                                                <%= blogList[featuredBlog].title %>
                                            </p>
                                        </div>
                                    </a>
                                </div>

                                <% totalBlog = 8;
                                for( let index=0; index < Math.min(blogList.length ,totalBlog); index++ ) { 
                                    if(index === featuredBlog){ 
                                        totalBlog = totalBlog + 1;
                                         continue; } %>
                                    <div class="blogList">
                                        <a href="/blog/<%= blogList[index].slug %>" class="blog-post">
                                            <div class="reco-image">
                                                <img src="<%= blogList[index].imageUrl %>"
                                                    alt="<%= blogList[index].slug %>" loading=" lazy">
                                                loading="lazy">
                                            </div>
                                            <div class="blogList-details">
                                                <p class="blogList-title">
                                                    <%= blogList[index].title %>
                                                </p>
                                                <p class="blogList-des" id="featBlogDes">
                                                    <%= blogList[index].metaDescription %>
                                                </p>
                                            </div>
                                        </a>
                                    </div>
                                <% } %>
                        </div>


                </section>
            </article>

    </main>
    <footer class="footer">
        <div class="footer-wrapper">

            <div class="f-col brand">
                <div class="logo">
                    <img src="/image/logo.png" alt="logo-image" class="logo-image">
                    <a href="/"><h2>Saniova</h2></a>
                </div>
                <p>Your hub for tech insights, blogs and futuristic ideas.</p>
            </div>

            <div class="f-col">
                <h4>Explore</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/blog">Blogs</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Community</h4>
                <ul>
                    <li><a href="https://www.facebook.com/share/1HMvQ11zft/">Facebook</a></li>
                    <li><a href="https://www.reddit.com/u/WerewolfMain3182/s/i6biQC9A6T">Reddit</a></li>
                    <li><a
                            href="https://www.quora.com/profile/Saniova?ch=10&oid=3168548346&share=f830d026&srid=5a8iLI&target_type=user">quora</a>
                    </li>
                    <li><a href="https://pin.it/5b77ei5Rx">Pinterest</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Legal</h4>
                <ul>
                    <li><a href="/privacy-policy">Privacy Policy</a></li>
                    <li><a href="/terms-&-conditions">Terms & Conditions</a></li>
                    <li><a href="/disclaimer">Disclaimer</a></li>
                </ul>
            </div>

        </div>

        <div class="footer-bottom">
            © 2025 Saniova — All rights reserved.
        </div>
    </footer>


    <script src="/script/share.js"></script>
    <script src="/script/blogdescriptional.js"></script>

</body>

</html>