<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= blog.metaDescription %>">
    <title>Wordora</title>
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap">
    
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap"></noscript>
    <link rel="stylesheet" href="/stylesheet/style.css">
    <link rel="stylesheet" href="/stylesheet/blog.css">
</head>
<body>
    <header>
            <nav>

                <div class="logo">
                    <h1>Wordora</h1>
                </div>
                <input type="checkbox" id="menu-toggle" style="display: none;">
                <label for="menu-toggle" class="hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </label>
                <div class="nav-link menu">
                    <a href="/">Home</a>
                    <a href="/blog">Blog</a>
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                </div>
            </nav>
        </navbar>
    </header>
    <main>

        <section class="blogSec">
            <article>

                
                <h1><%= blog.title %></h1>
                <div class="uploader">
                    <div class="uploader-img">
                        <img src="<%= blog.adminId.adminImage %>" alt="admin-profile-image" width="60" height="60">
                    </div>
                    <div class="uploader-det">
                        <p id="uploader-name"><%= blog.adminId.adminName %></p>
                        <p id="uploader-date"><%= blog.Date.toDateString() %></p>
                    </div>
                </div>
                <div class="blog-container">
                    <div class="content-container">

                        <div class="contentImg">
                            <img src="<%= blog.imageUrl %>" alt="<%= blog.slug %>" loading="lazy">
                        </div>
                        
                        <div class="content">
                            <p>
                                <%- blog.content %>
                            </p>
                        </div>
                    </div>
                    <aside class="aside">
                        <div class="author">
                            <img src="<%= blog.adminId.adminImage %>" alt="Author Profile" loading="lazy">
                            <p class="author-bio">
                                <%= blog.adminId.adminBio %>
                            </p>
                            
                        </div>
                        <div class="blogList">
                            <% for( let index = 0; index < Math.min(blogList.length ,12); index++ ) { %>
                            
                                <div class="blog-post">
                                    <img src="<%= blogList[index].imageUrl %>" alt="<%= blogList[index].slug %>">
                                    <div class="blogList-details">
                                        <p class="blogList-title"><%= blogList[index].title %></p>
                                        <p class="blogList-des">
                                            <%= blogList[index].metaDescription %>
                                        </p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </aside>
                </div>
            </article>
            
        </section>
    </main>
    <footer class="footer">
    <div class="footer-wrapper">

        <div class="f-col brand">
            <h2>Wordora</h2>
            <p>Your hub for tech insights, blogs and futuristic ideas.</p>
        </div>

        <div class="f-col">
            <h4>Explore</h4>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Blogs</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </div>

        <div class="f-col">
            <h4>Community</h4>
            <ul>
                <li><a href="#">Facebook</a></li>
                <li><a href="#">GitHub</a></li>
                <li><a href="#">Instagram</a></li>
                <li><a href="#">Twitter</a></li>
            </ul>
        </div>


    </div>

    <div class="footer-bottom">
        © 2025 Wordora — All rights reserved.
    </div>
</footer>

<script src="/script/script.js">
</script>


    </body>

</html>