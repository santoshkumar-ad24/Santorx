<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Google tag (gtag.js) -->
    <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-EQXHPKXBND"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-EQXHPKXBND');
</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= blog.metaDescription %>">
    <meta name="keywords" content="<%= blog.metaKeywords %>">
    <meta property="og:site_name" content="Saniova" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <title>
        <%= blog.title %> | Saniova
    </title>
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style"
        href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap">

    <noscript>
        <link rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Chelsea+Market&family=DM+Serif+Text:ital@0;1&family=Funnel+Sans:ital,wght@0,300..800;1,300..800&display=swap">
    </noscript>
    <link rel="stylesheet" href="/stylesheet/style.css">
    <link rel="stylesheet" href="/stylesheet/blog.css">
</head>

<body>
    <header>
        <nav>

            <div class="logo">
                <img src="/image/logo.png" alt="logo-image" class="logo-image">
                <h1>Saniova</h1>
            </div>
            <input type="checkbox" id="menu-toggle" style="display: none;">
            <label for="menu-toggle" class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </label>
            <div class="nav-link menu">
                <a href="/">Home</a>
                <a href="/blog">Blog</a>
                <a href="/about">About</a>
                <a href="/privacy-policy">Privacy</a>
                <a href="/contact">Contact</a>
            </div>
        </nav>
        </navbar>
    </header>
    <main>

        <section class="blogSec">
            <article>
                <!-- Hero Section with Title -->
                <div class="blog-hero">
                    <h1 class="blog-title">
                        <%= blog.title %>
                    </h1>

                    <!-- Author & Date Card -->
                    <div class="uploader">
                        <div class="uploader-img">
                            <img src="<%= blog.adminId.adminImage %>" alt="admin-profile-image" width="60" height="60">
                        </div>
                        <div class="uploader-det">
                            <p id="uploader-name">
                                <%= blog.adminId.adminName %>
                            </p>
                            <p id="uploader-date">
                                <%= blog.Date.toDateString() %>
                            </p>
                        </div>
                        <div class="blog-meta">
                            <span class="read-time">📖 3 min read</span>
                        </div>
                    </div>
                </div>

                <!-- Main Content Section -->
                <div class="blog-container">
                    <!-- Main Content -->
                    <div class="content-container">
                        <!-- Featured Image with Shadow -->
                        <div class="contentImg">
                            <img src="<%= blog.imageUrl %>" alt="<%= blog.slug %>" loading="lazy">
                        </div>

                        <!-- Blog Body Content -->
                        <div class="content">
                            <p>
                                <%- blog.content %>
                            </p>
                        </div>

                        <!-- Share Section -->
                        <div class="share-section">
                            <h3>Share this article</h3>
                            <div class="share-buttons">
                                <a href="#" id="shareBtn-facebook" class="share-btn facebook"
                                    title="Share on Facebook">f</a>
                                <a href="#" id="shareBtn-twitter" class="share-btn twitter"
                                    title="Share on Twitter">𝕏</a>
                                <a href="#" id="shareBtn-linkedin" class="share-btn linkedin"
                                    title="Share on LinkedIn">in</a>
                                <a href="#" id="copyLinkBtn" class="share-btn copy" title="Copy Link">🔗</a>
                            </div>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <aside class="aside">
                        <!-- Author Bio Card -->
                        <div class="author-card">
                            <img src="<%= blog.adminId.adminImage %>" alt="Author Profile" loading="lazy">
                            <h3>About the Author</h3>
                            <p class="author-bio">
                                <%= blog.adminId.adminBio %>
                            </p>
                            <div class="author-badge">Featured Writer</div>
                        </div>

                        <!-- Recommended Posts -->
                        <div class="blogList-container">
                            <h3 class="recommended-title">📚 Recommended Posts</h3>
                            <div class="blogList">
                                <% for( let index=0; index < Math.min(blogList.length ,12); index++ ) { %>

                                    <a href="/blog/<%= blogList[index].slug %>" class="blog-post">
                                        <img src="<%= blogList[index].imageUrl %>" alt="<%= blogList[index].slug %>">
                                        <div class="blogList-details">
                                            <p class="blogList-title">
                                                <%= blogList[index].title %>
                                            </p>
                                            <p class="blogList-des" id="featBlogDes">
                                                <%= blogList[index].metaDescription %>
                                            </p>
                                        </div>
                                    </a>
                                    <% } %>
                            </div>
                        </div>
                    </aside>
                </div>
            </article>

        </section>
    </main>
    <footer class="footer">
        <div class="footer-wrapper">

            <div class="f-col brand">
                <div class="logo">
                    <img src="/image/logo.png" alt="logo-image" class="logo-image">
                    <h1>Saniova</h1>
                </div>
                <p>Your hub for tech insights, blogs and futuristic ideas.</p>
            </div>

            <div class="f-col">
                <h4>Explore</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/blog">Blogs</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Community</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">GitHub</a></li>
                    <li><a href="#">Instagram</a></li>
                    <li><a href="#">Twitter</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Legal</h4>
                <ul>
                    <li><a href="/privacy-policy">Privacy Policy</a></li>
                    <li><a href="/terms-&-conditions">Terms & Conditions</a></li>
                    <li><a href="/disclaimer">Disclaimer</a></li>
                </ul>
            </div>

        </div>

        <div class="footer-bottom">
            © 2025 Saniova — All rights reserved.
        </div>
    </footer>


    <script src="/script/share.js"></script>
    <script src="/script/blogdescriptional.js"></script>

</body>

</html>