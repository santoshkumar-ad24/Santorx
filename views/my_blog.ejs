    </header>

    <section class="blog_section">
        <div class="title">
            <h2>The Feed</h2>
            <p class="blog-subtitle">
                Learn AI, tech skills, and future trends with practical, student‑friendly articles.
            </p>
        </div>

        <!-- START HERE / FEATURED SECTION -->
        <section class="start-here">
            <h3>Start Here</h3>
            <p>
                New to Saniova? Begin with these handpicked posts to understand AI skills, projects, and future tech
                careers.
            </p>
            <div class="start-here-grid">
                <%
                const featured=blog .filter(b=> b.featured)
                    .slice(0, 3);

                    const fallbackFeatured = blog.slice(0, 3);
                    const startHerePosts = featured.length ? featured : fallbackFeatured;
                    %>
                    <% startHerePosts.forEach(post=> { %>
                        <a href="/blog/<%= post.slug %>" class="start-here-card">


                            <img class="featured-post-image" src="<%= post.imageUrl %>" alt="<%= post.slug %>">
                            <span class="start-here-category">
                                <%= post.category %>
                            </span>
                            <h4>
                                <%= post.title %>
                            </h4>
                            <p class="blog-excerpt">
                                <%= post.metaDescription %>
                            </p>
                        </a>
                        <% }) %>
            </div>
        </section>


        <!-- Category Filter (from your existing categories) -->
        <div class="category-filter">
            <button class="filter-btn active" data-category="all">All</button>
            <% const categories=[...new Set(blog.map(b=> b.category).filter(c => c))];
                categories.forEach(category => {
                %>
                <button class="filter-btn" data-category="<%= category %>">
                    <%= category %>
                </button>
                <% }); %>
        </div>

        <div class="blogs-container" id="blogs-container">
            <% 
            // Group blogs by category
            const groupedBlogs = {};
            blog.forEach(b => {
              if (!groupedBlogs[b.category]) groupedBlogs[b.category] = [];
              groupedBlogs[b.category].push(b);
            });
            
            // Sort categories (Future Trends first)
            const categoryOrder = Object.keys(groupedBlogs).sort((a,b) => {
              if (a === 'Future Trends') return -1;
              if (b === 'Future Trends') return 1;
              return a.localeCompare(b);
            });
            
            // Render each category group
            categoryOrder.forEach((category) => {
              const categoryBlogs = groupedBlogs[category];
              const itemsToShow = 6;
              const hasMore = categoryBlogs.length > itemsToShow;
            %>
              <div class="category-group" data-category="<%= category %>">
                <div class="category-header">
                  <h3 class="category-group-title"><%= category %></h3>
                  <span class="category-count"><%= categoryBlogs.length %> articles</span>
                </div>
                
                <div class="article" data-group="<%= category %>">
                  <% categoryBlogs.slice(0, itemsToShow).forEach((b) => { %>
                    <div class="blogs-card" data-category="<%= b.category %>">
                      <div class="img-blog">
                        <img src="<%= b.imageUrl %>" alt="<%= b.title %>">
                      </div>
                      <div class="blog-card-content">
                        <span class="blog-category">
                          <%= b.category %>
                        </span>

                        <h2 class="blog-title">
                          <%= b.title %>
                        </h2>

                        <p class="blog-excerpt">
                          <%= b.metaDescription %>
                        </p>

                        <div class="blog-footer">
                          <span class="blog-date">
                            <%= b.Date.toDateString() %>
                          </span>
                          <a href="/blog/<%= b.slug %>" class="read-more-myblog">Read Article →</a>
                        </div>
                      </div>
                    </div>
                  <% }); %>

                  <% categoryBlogs.slice(itemsToShow).forEach((b) => { %>
                    <div class="blogs-card" data-category="<%= b.category %>" data-hidden="true" style="display: none;">
                      <div class="img-blog">
                        <img src="<%= b.imageUrl %>" alt="<%= b.title %>">
                      </div>
                      <div class="blog-card-content">
                        <span class="blog-category">
                          <%= b.category %>
                        </span>

                        <h2 class="blog-title">
                          <%= b.title %>
                        </h2>

                        <p class="blog-excerpt">
                          <%= b.metaDescription %>
                        </p>

                        <div class="blog-footer">
                          <span class="blog-date">
                            <%= b.Date.toDateString() %>
                          </span>
                          <a href="/blog/<%= b.slug %>" class="read-more-myblog">Read Article →</a>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                </div>

                <% if (hasMore) { %>
                  <div class="load-more-wrapper">
                    <button class="load-more-btn" data-category="<%= category %>" data-total="<%= categoryBlogs.length %>" data-shown="<%= itemsToShow %>">
                      Load More (<%= categoryBlogs.length - itemsToShow %> more)
                    </button>
                  </div>
                <% } %>
              </div>
            <% }); %>
        </div>
    </section>

    <!-- NEWSLETTER / FEEDBACK SECTION WITH CLEAR CTA -->
    <section class="feedback-sec">
        <div class="feedback">
            <form action="/feedback" method="post">
                <div class="fullN">
                    <div class="partN">

                        <label for="firstname">First Name</label>
                        <input type="text" name="firstName" id="firstname">
                    </div>
                    <div class="partN">

                        <label for="lastname">Last Name</label>
                        <input type="text" name="lastName" id="lastname">
                    </div>
                </div>

                <div class="form-ele">

                    <label for="emailadd">Email</label>
                    <input type="email" name="email" id="emailadd">
                </div>

                <div class="form-ele">

                    <label for="msg">Leave us a message...</label>
                    <textarea name="message" id="msg"></textarea>

                </div>

                <div class="form-ele">
                    <button type="submit" class="submit">Submit</button>
                </div>

            </form>
        </div>
    </section>

