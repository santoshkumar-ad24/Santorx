<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Santorx</title>
    <link rel="stylesheet" href="stylesheet/style.css">
    <link rel="stylesheet" href="stylesheet/my_blog.css">
</head>

<body>
    <header>
        <navbar>
            
            <nav>

                <div class="logo">
                    <h1>Santorx</h1>
                </div>
                <input type="checkbox" id="menu-toggle" style="display: none;">
                <label for="menu-toggle" class="hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </label>
                <div class="nav-link menu">
                    <a href="/">Home</a>
                    <a href="/blog">Blog</a>
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                </div>
            </nav>
        </navbar>
    </header>

    <section class="blog_section">
        <div class="title">
            <h2>The Feed</h2>
        </div>

        <!-- Category Filter -->
        <div class="category-filter">
            <button class="filter-btn active" data-category="all">All</button>
            <% 
                // Extract unique categories from blogs
                const categories = [...new Set(blog.map(b => b.category).filter(c => c))];
                categories.forEach(category => { 
            %>
                <button class="filter-btn" data-category="<%= category %>"><%= category %></button>
            <% }); %>
        </div>

        <div class="article">
            <% for( let index = 0; index < blog.length; index++ ) { %>
        

            <div class="blogs-card" data-category="<%= blog[index].category %>">
                <div class="img-blog">
                    <img src="<%=blog[index].imageUrl %>" alt="<%= blog[index].title %>">
                </div>
                <div class="blog-card-content">
                    <span class="blog-category"><%= blog[index].category %></span>

                    <h2 class="blog-title">
                        <%= blog[index].title %>
                    </h2>

                    <p class="blog-excerpt">
                        <%= blog[index].metaDescription %>
                    </p>

                    <div class="blog-footer">
                        <span class="blog-date"><%= blog[index].Date.toDateString() %></span>
                        <a href="/blog/<%= blog[index].slug %>" class="read-more">Read Article →</a>
                    </div>
                </div>
            </div>
            <% } %>
        </div>

    </section>


    <section class="feedback-sec">
        <div class="feedback">
            <form action="/feedback" method="post">
                <div class="fullN">
                    <div class="partN">

                        <label for="firstname">First Name</label>
                        <input type="text" name="firstName" id="firstname">
                    </div>
                    <div class="partN">

                        <label for="lastname">Last Name</label>
                        <input type="text" name="lastName" id="lastname">
                    </div>
                </div>

                <div class="form-ele">

                    <label for="emailadd">Email</label>
                    <input type="email" name="email" id="emailadd">
                </div>

                <div class="form-ele">

                    <label for="msg">Leave us a message...</label>
                    <textarea name="message" id="msg"></textarea>

                </div>

                <div class="form-ele">
                    <button type="submit" class="submit">Submit</button>
                </div>

            </form>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-wrapper">

            <div class="f-col brand">
                <h2>Santorx</h2>
                <p>Your hub for tech insights, blogs and futuristic ideas.</p>
            </div>

            <div class="f-col">
                <h4>Explore</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                <li><a href="/blog">Blogs</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Community</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">GitHub</a></li>
                    <li><a href="#">Instagram</a></li>
                    <li><a href="#">Twitter</a></li>
                </ul>
            </div>


        </div>

        <div class="footer-bottom">
            © 2025 Santorx — All rights reserved.
        </div>
    </footer>
<script src="/script/blogCardHeight.js"></script>
<script src="/script/script.js"></script>
<script src="/script/blogdescriptional.js"></script>  
</body>

</html>