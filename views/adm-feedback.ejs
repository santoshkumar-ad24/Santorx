
        <!DOCTYPE html>
        <html lang="en">

        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>Santorx Admin | Command Center</title>

            <link rel="stylesheet" href="/stylesheet/admFeedback.css">
            <link rel="stylesheet" href="/stylesheet/admin-dash.css">
            <!-- FontAwesome for Icons -->
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        </head>

        <body>

            <div class="admin-layout">
                <!-- Modern Vertical Sidebar -->
                <aside class="sidebar">
                    <div class="sidebar-top">
                        <div class="logo">
                            <h1>Santorx</h1>
                        </div>
                    </div>

                    <nav class="sidebar-menu">
                        <a href="/admin/dashboard" class="menu-item">
                            <i class="fas fa-chart-line"></i> <span>Dashboard</span>
                        </a>
                        <a href="/admin/details" class="menu-item">
                            <i class="fas fa-user-shield"></i> <span>Profile</span>
                        </a>
                        <a href="/admin/dashboard/feedback" class="menu-item  active">
                            <i class="fas fa-comment-dots"></i> <span>FeedBack</span>
                        </a>
                        <a href="/admin/dashboard/contact-inqury" class="menu-item">
                            <i class="fas fa-envelope-open-text"></i> <span>Inquiry</span>
                        </a>
                    </nav>

                    <div class="sidebar-bottom">
                        <a href="/" class="external-link">
                            <i class="fas fa-eye"></i> <span>View Site</span>
                        </a>
                    </div>
                </aside>

                <!-- Main Workspace -->
                <main class="workspace">
                    <!-- Top Navigation Bar -->
                    <header class="top-nav">
                <div class="nav-left">
                    <a href="/admin/details" class="profile-link">
                        <div class="profileImg">
                            <img src="<%= blog[0].adminId.adminImage %>" alt="Profile">
                        </div>
                    </a>
                </div>
                <div class="nav-right">
                    <a href="/admin/dashboard/create-blog" class="action-btn">
                        <i class="fas fa-plus"></i> Add New Blog
                    </a>
                    
                </div>
            </header>

                    <!-- Stats Highlight Grid -->
                    <section class="adm-feedback-sec">
                        <h2>User Feedback</h2>
                        <div class="adm-feedback-container">
                            <% for( let index = 0; index < Math.min(userFeedback.length, 20); index++ ) { %>
                            
                                <div class="Admfeedback-card">
                                    <p class="Admfeedback-user"><strong class="feedName"><%= userFeedback[index].firstName %></strong> <strong
                                        class="feedName"><%= userFeedback[index].lastName %></strong></p>
                                        <p class="Admfeedback-email"><%= userFeedback[index].email %></p>
                                        <p class="Admfeedback-message"><%= userFeedback[index].message %></p>
                                        <p ><%= userFeedback[index].Date.toDateString() %></p>
                                    </div>
                                    <% } %>
                            
                        </div>
                    </section>
                </main>
            </div>








        </body>

        </html>

