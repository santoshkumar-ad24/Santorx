
    <!DOCTYPE html>
    <html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Saniova Admin | Command Center</title>

        <link rel="stylesheet" href="/stylesheet/admin-details.css">
        <link rel="stylesheet" href="/stylesheet/admin-dash.css">
        <!-- FontAwesome for Icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        
        <!-- Vercel Web Analytics -->
        <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
    </head>

    <body>

        <div class="admin-layout">
            <!-- Modern Vertical Sidebar -->
            <aside class="sidebar">
                <div class="sidebar-top">
                    <div class="logo">
                    <img src="/image/logo.png" alt="logo-image" class="logo-image">
                    <h2>Saniova</h2>
                </div>
                </div>

                <nav class="sidebar-menu">
                    <a href="/admin/dashboard" class="menu-item">
                        <i class="fas fa-chart-line"></i> <span>Dashboard</span>
                    </a>
                    <a href="/admin/details" class="menu-item active">
                        <i class="fas fa-user-shield"></i> <span>Profile</span>
                    </a>
                    <a href="/admin/dashboard/feedback" class="menu-item">
                        <i class="fas fa-comment-dots"></i> <span>FeedBack</span>
                    </a>
                    <a href="/admin/dashboard/contact-inqury" class="menu-item">
                        <i class="fas fa-envelope-open-text"></i> <span>Inquiry</span>
                    </a>
                </nav>

                <div class="sidebar-bottom">
                    <a href="/" class="external-link">
                        <i class="fas fa-eye"></i> <span>View Site</span>
                    </a>
                </div>
            </aside>

            <!-- Main Workspace -->
            <main class="workspace">
                <!-- Top Navigation Bar -->
                <header class="top-nav">
                    <div class="nav-left">
                        <div class="logo">
                            <h2>Saniova</h2>
                        </div>
                    </div>
                    <div class="nav-right">
                        <a href="/admin/dashboard/create-blog" class="action-btn">
                            <i class="fas fa-plus"></i> Add New Blog
                        </a>

                    </div>
                </header>

                <!-- Stats Highlight Grid -->
                <section class="admin-details">
                    <div class="details-container">
                        <h2>Admin Details</h2>
                        <div class="profile-image">
                            <div class="image-circle" id="image-circle">
                                <img id="profile-img" src="<%= adminImage %>" alt="Profile Image">
                                <form action="/cloud/admin/details/uploader-img" method="post" id="uploadForm"
                                    enctype="multipart/form-data">
                                    <div type="button" class="edit-overlay" id="edit-overlay">
                                        <span>Edit</span>
                                    </div>
                                    <div>

                                        <input type="file" id="image-upload" name="profile" accept="image/*" hidden>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="details-info">
                            <p><strong>Admin Name:</strong>
                                <%= adminName %>
                            </p>
                            <p><strong>Username:</strong>
                                <%= adminUser %>
                            </p>
                            <p><strong>Joined Date:</strong>
                                <%= joinDate %>
                            </p>
                        </div>

                    </div>
                </section>
            </main>
        </div>








        <script src="/script/admin-details.js"></script>
    </body>

    </html>